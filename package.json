{
  "name": "ftm",
  "version": "0.2.0",
  "main": "./out/main/index.js",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^37.4.0",
    "electron-vite": "^2.0.0",
    "vite": "^5.4.0",
    "vite-plugin-bytecode": "^0.0.0",
    "electron-builder": "^25.1.8",
    "cross-env": "^10.0.0",
    "crypto-js": "^4.2.0",
    "clean-css-cli": "^5.6.3",
    "html-minifier-terser": "^7.2.0",
    "javascript-obfuscator": "^4.1.1",
    "@types/node": "^22.0.0"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "cheerio": "^1.1.2"
  },
  "keywords": [],
  "author": "bilibili@禾傀",
  "license": "CC BY-ND",
  "description": "",
  "build": {
    "productName": "风灵月影宗",
    "appId": "com.hekui.flingtrainerdownloader",
    "copyright": "Copyright © 2025",
    "asar": true,
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "out/**/*",
      "icon.ico",
      "pic/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}