{
  "name": "ftm",
  "version": "0.1.7",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "clean": "rm -rf node_modules && rm package-lock.json"
  },
  "devDependencies": {
    "electron": "^37.4.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "cheerio": "^1.1.2"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "build": {
    "productName": "风灵月影宗",
    "appId": "com.hekui.flingtrainerdownloader",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "src/",
      "node_modules/"
    ]
  }
}
